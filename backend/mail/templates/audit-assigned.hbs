<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Audit Assigned</title></head>
<body style="margin:0;padding:0;background-color:#eef1f5;font-family:Arial,Helvetica,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#eef1f5;padding:32px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;">
          {{> header}}
          <tr>
            <td style="padding:32px;">
              <h2 style="margin:0 0 16px;font-size:20px;color:#1a2333;">New Audit Assigned</h2>
              <p style="margin:0 0 12px;font-size:14px;line-height:22px;color:#3c4657;">
                Hi {{default employeeName "there"}},
              </p>
              <p style="margin:0 0 20px;font-size:14px;line-height:22px;color:#3c4657;">
                You have been assigned as the auditor for a new audit. Details are below.
              </p>
              <table role="presentation" width="100%" style="border-collapse:collapse;margin-bottom:8px;">
                <tr><td style="padding:8px 0;font-size:13px;color:#8a94a3;width:140px;">Audit ID</td><td style="padding:8px 0;font-size:13px;color:#1a2333;font-weight:600;">{{auditId}}</td></tr>
                <tr><td style="padding:8px 0;font-size:13px;color:#8a94a3;">Audit Name</td><td style="padding:8px 0;font-size:13px;color:#1a2333;font-weight:600;">{{auditName}}</td></tr>
                <tr><td style="padding:8px 0;font-size:13px;color:#8a94a3;">Assigned By</td><td style="padding:8px 0;font-size:13px;color:#1a2333;font-weight:600;">{{assignedBy}}</td></tr>
                <tr><td style="padding:8px 0;font-size:13px;color:#8a94a3;">Due Date</td><td style="padding:8px 0;font-size:13px;color:#c0392b;font-weight:600;">{{formatDate dueDate}}</td></tr>
              </table>
              {{#if remarks}}
              <p style="margin:16px 0 0;font-size:13px;line-height:20px;color:#3c4657;background:#f4f6f8;padding:12px 14px;border-radius:6px;">
                <strong>Remarks:</strong> {{remarks}}
              </p>
              {{/if}}
              {{> button buttonText="View Audit"}}
            </td>
          </tr>
          {{> footer}}
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
