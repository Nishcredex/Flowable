<tr>
  <td style="background-color:#0f2f5f;padding:24px 32px;border-radius:8px 8px 0 0;">
    <table role="presentation" width="100%">
      <tr>
        <td align="left">
          {{#if logoUrl}}
            <img src="{{logoUrl}}" alt="{{default companyName "Audit Management System"}}" height="32" style="display:block;" />
          {{else}}
            <span style="font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:700;color:#ffffff;letter-spacing:0.5px;">
              {{default companyName "AUDIT MANAGEMENT SYSTEM"}}
            </span>
          {{/if}}
        </td>
      </tr>
    </table>
  </td>
</tr>
